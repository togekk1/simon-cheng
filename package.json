{
  "name": "simon-cheng",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "https://github.com/togekk1/simon-cheng.git",
  "author": "togekk <togekk@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "assemblyScript": "https://github.com/AssemblyScript/assemblyscript.git",
    "babel-types": "^6.26.0",
    "base64-js": "^1.3.1",
    "bulma": "^0.8.1",
    "parcel-bundler": "^1.12.4",
    "typescript": "^3.8.3"
  },
  "scripts": {
    "asbuild": "asc src/wasm/assembly/index.ts -O3 -b build/index.wasm --validate",
    "asbuild_dev": "asc src/wasm/assembly/index.ts -b dist/index.wasm --validate --sourceMap",
    "start": "yarn asbuild_dev && parcel src/index.html",
    "build": "del build /S /Q && yarn asbuild && parcel build src/index.html --no-source-maps --out-dir build --public-url ./",
    "test": "node tests"
  },
  "dependencies": {
    "@assemblyscript/loader": "^0.9.4"
  }
}